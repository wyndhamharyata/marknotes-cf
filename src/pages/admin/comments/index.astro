---
export const prerender = false;

import BaseAdminLayout from "../../../layouts/BaseAdminLayout.astro";
import { SITE_DESCRIPTION, SITE_TITLE, ADMIN_DOCK } from "../../../consts";
import { type ModerationStatusType } from "../../../lib/comments/types";
import CommentFilter from "./_components/CommentFilter.astro";
import CommentList from "./_components/CommentList.astro";

const url = new URL(Astro.request.url);
const statusParam = url.searchParams.get("status");
const pageParam = url.searchParams.get("page");

let filterStatus: ModerationStatusType | null = null;
if (statusParam !== null) {
  const statusNum = parseInt(statusParam, 10);
  if ([0, 1, 2, 3].includes(statusNum)) {
    filterStatus = statusNum as ModerationStatusType;
  }
}

const currentPage = Math.max(1, parseInt(pageParam ?? "1", 10) || 1);
const limit = 10;
const baseUrl =
  filterStatus !== null ? `/admin/comments?status=${filterStatus}` : "/admin/comments";
---

<BaseAdminLayout
  title={SITE_TITLE}
  description={SITE_DESCRIPTION}
  dockProp={{ menus: ADMIN_DOCK, currentPath: "/admin/comments" }}
>
  <div class="mx-auto flex flex-col space-y-6 md:w-3xl">
    <h1 class="text-2xl font-bold">Comment Moderation</h1>

    <CommentFilter server:defer filterStatus={filterStatus}>
      <div
        slot="fallback"
        class="text-base-content/60 flex min-h-12 items-center justify-center"
      >
        Loading filters…
      </div>
    </CommentFilter>

    <CommentList
      server:defer
      filterStatus={filterStatus}
      currentPage={currentPage}
      limit={limit}
      baseUrl={baseUrl}
    >
      <div slot="fallback" class="card bg-base-100/60 p-8 text-center">
        <p class="text-base-content/60">Loading comments…</p>
      </div>
    </CommentList>
  </div>
</BaseAdminLayout>
